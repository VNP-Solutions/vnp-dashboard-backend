# =============================================================================
# VNP Dashboard Backend — local development (no Docker)
# =============================================================================
# Swagger: http://localhost:5001/api/docs
# API base: http://localhost:5001/api
# Portfolio sync-create (from DBMS): POST /api/portfolio/sync-create
# =============================================================================

NODE_ENV=development
DEPLOYMENT_ENV=development
PORT=5001
APP_NAME='VNP Dashboard'

# Database (Atlas or local MongoDB — separate DB from DBMS/Scraper recommended)
DATABASE_URL=mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority&appName=VnpParser&tlsAllowInvalidCertificates=true

# User auth JWT (Dashboard app only)
JWT_ACCESS_SECRET=<jwt-access-secret>
JWT_REFRESH_SECRET=<jwt-refresh-secret>
JWT_ACCESS_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=14d

# Cross-backend sync auth (Scraper ↔ Dashboard audit import; DBMS → Dashboard portfolio sync)
# MUST be identical on DBMS, Dashboard, and Scraper.
JWT_COMMUNICATION_SECRET=local-dev-communication-secret-change-me

# Inbound service-token auth (property sync endpoints still using X-Service-Token)
# DBMS property sync sends this value as X-Service-Token header.
SERVICE_TOKEN=local-dev-service-token-change-me
DBMS_SERVICE_TOKEN=local-dev-service-token-change-me
SCRAPER_SERVICE_TOKEN=local-dev-service-token-change-me

# Public URL of this Dashboard API (callbacks / external links)
EXTERNAL_BASE_URL=http://localhost:5001

# SQS (optional — leave empty for local unless testing audit import queue)
AUDIT_IMPORT_QUEUE_URL=

# AWS S3
S3_BUCKET_NAME=<s3-bucket-name>
S3_REGION=<s3-region>
S3_ACCESS_KEY=<s3-access-key>
S3_SECRET_KEY=<s3-secret-key>
S3_BUCKET_URL=<s3-bucket-url>

# SMTP
SMTP_EMAIL=<smtp-email>
SMTP_PASSWORD=<smtp-password>

INVITATION_REDIRECT_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:3000

PARALLEL_WORKERS=8
